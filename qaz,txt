<!-- ПОДКЛЮЧЕНИЕ БИБЛИОТЕКИ И СКРИПТ ОТПРАВКИ -->
<script type="text/javascript" src="https://jsdelivr.net"></script>
<!-- 1. ПОДКЛЮЧЕНИЕ ВНЕШНЕЙ БИБЛИОТЕКИ EMAILJS (Обязательно должно идти первым) -->
<script type="text/javascript" src="https://jsdelivr.net"></script>

<!-- 2. ЕДИНЫЙ ОБЪЕДИНЕННЫЙ СКРИПТ ВСЕГО САЙТА -->
<script type="text/javascript">

    // --- ИНИЦИАЛИЗАЦИЯ EMAILJS ---
    (function(){
        emailjs.init("z_xwGUMkpyyforyJi"); // Твой проверенный Public Key
    })();

    // --- ГЛОБАЛЬНЫЕ НАСТРОЙКИ И ПЕРЕМЕННЫЕ ---
    let currentAudio = null;
    const playlist = [
        { name: "Трек 1", file: "музяка/1.mp3" },
        { name: "Трек 2", file: "музяка/2.mp3" },
        { name: "Трек 3", file: "музяка/3.mp3" }
    ];

    const localBase = 'icons/';
    const totalIcons = 61;
    const windowsIcons = [];
    for (let i = 1; i <= totalIcons; i++) {
        windowsIcons.push(`${i}.ico`);
    }

    const getRandom = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

    // --- ФУНКЦИЯ 1: СМЕНА СТИЛЕЙ СТРАНИЦЫ ---
    function changeStyle(sheetName) {
        const themeStyle = document.getElementById('theme-style');
        if (themeStyle) {
            themeStyle.setAttribute('href', sheetName);
        }
    }

    // --- ФУНКЦИЯ 2: МУЗЫКАЛЬНЫЙ ПЛЕЕР ---
    function playRandomMusic() {
        if (currentAudio) {
            currentAudio.pause();
            currentAudio.currentTime = 0;
        }

        const randomTrack = playlist[Math.floor(Math.random() * playlist.length)];
        currentAudio = new Audio(randomTrack.file);
        currentAudio.play().catch(e => console.log("Файл не найден. Проверьте папку 'музяка'"));

        const statusNode = document.getElementById('playerStatus');
        const nameNode = document.getElementById('trackName');

        if (nameNode) nameNode.innerText = randomTrack.name;
        if (statusNode) statusNode.style.display = 'block';
    }

    // --- ФУНКЦИЯ 3: ЛОГИКА ПЕРЕТАСКИВАНИЯ ИКОНОК (DRAG & DROP) ---
    function makeIconDraggable(img) {
        let isDragging = false;
        let isMoved = false;
        let startX, startY;
        let shiftX, shiftY;

        img.addEventListener('mousedown', function(e) {
            if (e.button !== 0) return; // Только левая кнопка мыши

            startX = e.clientX;
            startY = e.clientY;
            isMoved = false;
            isDragging = true;

            const rect = img.getBoundingClientRect();
            shiftX = e.clientX - rect.left;
            shiftY = e.clientY - rect.top;

            img.style.zIndex = '1'; // Иконка всегда на самом нижнем слое
            e.preventDefault();
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging) return;

            if (Math.abs(e.clientX - startX) > 5 || Math.abs(e.clientY - startY) > 5) {
                isMoved = true;
            }

            let newX = e.clientX - shiftX;
            let newY = e.clientY - shiftY + window.scrollY;

            img.style.left = `${newX}px`;
            img.style.top = `${newY}px`;
            img.style.transform = `rotate(${img.dataset.angle}deg)`; // Сохраняем наклон при движении
        });

        document.addEventListener('mouseup', function(e) {
            if (!isDragging) return;
            isDragging = false;

            img.style.zIndex = '1';

            // Если зажали и не двигали — это клик, запускаем музыку
            if (!isMoved) {
                playRandomMusic();
            }
        });

        img.ondragstart = function() { return false; };
    }

    // --- ФУНКЦИЯ 4: ГЕНЕРАЦИЯ ИКОНКАМИ И АВТО-ФИКС СЛОЕВ ПОСЛЕ ЗАГРУЗКИ ---
    function generateRetroIcons() {
        const iconCount = getRandom(50, 80);
        const spawnedIcons = [];
        const minDistance = 70;
        const screenWidth = window.innerWidth;

        const screenHeight = Math.max(
            document.body.scrollHeight, document.documentElement.scrollHeight,
            document.body.offsetHeight, document.documentElement.offsetHeight,
            document.body.clientHeight, document.documentElement.clientHeight
        );

        for (let i = 0; i < iconCount; i++) {
            const img = document.createElement('img');
            const randomIconFile = windowsIcons[getRandom(0, windowsIcons.length - 1)];

            img.src = `${localBase}${randomIconFile}`;
            img.classList.add('retro-icon');
            img.alt = 'Windows 95 Icon';

            // Жёсткие стили для позиционирования под карточками
            img.style.position = 'absolute';
            img.style.pointerEvents = 'auto';
            img.style.cursor = 'move';
            img.style.userSelect = 'none';
            img.style.webkitUserSelect = 'none';
            img.style.zIndex = '1';

            let posX, posY;
            let attempts = 0;
            let tooClose = false;

            do {
                tooClose = false;
                posX = getRandom(30, screenWidth - 80);
                posY = getRandom(30, screenHeight - 80);
                attempts++;

                for (let icon of spawnedIcons) {
                    const dist = Math.hypot(posX - icon.x, posY - icon.y);
                    if (dist < minDistance) {
                        tooClose = true;
                        break;
                    }
                }
            } while (tooClose && attempts < 60);

            spawnedIcons.push({ x: posX, y: posY });

            const randomAngle = getRandom(-45, 45);
            img.dataset.angle = randomAngle;

            img.style.left = `${posX}px`;
            img.style.top = `${posY}px`;
            img.style.transform = `rotate(${randomAngle}deg)`;

            document.body.appendChild(img);
            makeIconDraggable(img);
        }

        // Авто-фикс слоев: поднимаем все блоки div (карточки "тут нечего" и форму) над иконками
        const allDivs = document.querySelectorAll('div');
        allDivs.forEach(div => {
            const currentPosition = window.getComputedStyle(div).position;
            if (currentPosition === 'static') {
                div.style.position = 'relative';
            }
            div.style.zIndex = '10'; // Карточки выше иконок
        });

        // Принудительно выставляем контейнер формы еще выше, на передний план
        const feedbackBox = document.querySelector('.feedback-box');
        if (feedbackBox) {
            feedbackBox.style.position = 'relative';
            feedbackBox.style.zIndex = '20';
        }
    }

    // --- ГЛАВНЫЙ ИНИЦИАЛИЗАТОР СОБЫТИЙ ПОСЛЕ ЗАГРУЗКИ СТРАНИЦЫ ---
    window.addEventListener('load', function() {

        // 1. Запускаем генерацию иконок
        generateRetroIcons();

        // 2. Настраиваем перехват клика кнопки "Озвучить" для отправки через EmailJS
        const voiceButton = document.querySelector('.custom-btn.btn-1');
        const formStatus = document.getElementById('form-status');

        if (voiceButton) {
            voiceButton.addEventListener('click', function() {
                const myForm = document.getElementById('contact-form');

                // Проверка валидности заполнения формы
                if (myForm && !myForm.checkValidity()) {
                    myForm.reportValidity();
                }

                if (formStatus) {
                    formStatus.style.display = 'block';
                    return;
                    formStatus.style.color = 'black';
                    formStatus.innerText = 'Отправка...';
                }

                const serviceID = 'service_botyk3h';
                const templateID = 'template_w1k7ku4';

                emailjs.sendForm(serviceID, templateID, myForm)
                    .then(function() {
                        console.log('Успешно отправлено на quenesi@proton.me!');
                        if (formStatus) {
                            formStatus.style.color = 'green';
                            formStatus.innerText = 'Успешно доставлено в Proton Mail!';
                        }
                        if (myForm) myForm.reset();
                    }, function(error) {
                        console.error('Ошибка EmailJS:', error);
                        if (formStatus) {
                            formStatus.style.color = 'red';
                            formStatus.innerText = 'Ошибка при отправке.';
                        }
                    });
            });
        }
    });
</script>






