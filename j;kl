        html {
            scroll-behavior: smooth;
        }
        body {
            margin: 0;
            font-family: "MS Sans Serif", Geneva, sans-serif; /* Родной шрифт Windows 95 */
            background-color: #008080; /* Тот самый культовый стандартный цвет рабочего стола (Teal) */
            position: relative;
            padding: 0;
            min-height: 100vh;
        }

        /* ВЕРХНЯЯ ПАНЕЛЬ КАК СТАНДАРТНОЕ ОКНО WINDOWS */
        .topbar {
            position: fixed;
            top: 10px;
            left: 10%;
            width: 80%;
            height: 60px;
            background-color: #c0c0c0; /* Стандартный серый цвет панелей (Silver) */
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            z-index: 1000;
            margin-right: auto;

            /* Знаменитая трехмерная выпуклая рамка Windows 95 */
            border-top: 2px solid #fff;
            border-left: 2px solid #fff;
            border-right: 2px solid #808080;
            border-bottom: 2px solid #808080;
            box-shadow: 1px 1px 0px 0px #000;
        }

        /* КНОПКИ В СТИЛЕ WINDOWS 95 */
        .topbar a {
            color: #000000;
            text-decoration: none;
            padding: 6px 18px;
            background-color: #c0c0c0;
            font-weight: normal;
            font-size: 14px;

            /* Выпуклая кнопка */
            border-top: 2px solid #fff;
            border-left: 2px solid #fff;
            border-right: 2px solid #808080;
            border-bottom: 2px solid #808080;
            box-shadow: 1px 1px 0px 0px #000;
            transition: none; /* В 1995 году не было плавных анимаций */
        }

        .topbar a:hover {
            background-color: #dcdcdc; /* Легкий отсвет при наведении */
        }

        /* Эффект физического вдавливания кнопки при клике */
        .topbar a:active {
            border-top: 2px solid #808080;
            border-left: 2px solid #808080;
            border-right: 2px solid #fff;
            border-bottom: 2px solid #fff;
            box-shadow: none;
            transform: translate(1px, 1px);
        }

        .section {
            min-height: 85vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
            font-size: 2rem;
            color: #000000;
            background: none;
            border: none;
            box-sizing: border-box;
        }

        /* СИНЯЯ ЗОНА С ПАДЖЕМ — ТЕПЕРЬ КАК ОКНО ПРИЛОЖЕНИЯ ИЛИ ОБОИ */
        .texture-rectangle {
            position: relative;
            width: 100%;
            max-width: 1000px;
            height: 524px;
            margin: 30px auto;
            box-sizing: border-box;
            background-color: #4376dc; /* Синий экран */
            background-size: 40px 40px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 40px;

            /* Вдавленная классическая рамка */
            border-top: 2px solid #808080;
            border-left: 2px solid #808080;
            border-right: 2px solid #fff;
            border-bottom: 2px solid #fff;

            background-image:
                linear-gradient(to right, rgb(0 0 0 / 0.15) 4px, transparent 4px),
                linear-gradient(to bottom, rgb(0 0 0 / 0.15) 4px, transparent 4px);
        }

        .texture-rectangle .image-wrapper {
            position: absolute;
            top: 0;
            left: 0;
            width: 50%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: smoothFlyIn 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        .texture-rectangle img {
            width: 80%;
            height: 80%;
            object-fit: contain;
            transition: opacity 0.4s ease-in-out;
            image-rendering: pixelated; /* Четкие пиксели для духа эпохи */
        }

        .texture-rectangle .img-base { position: relative; z-index: 1; }
        .texture-rectangle .img-hover { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2; opacity: 0; }
        .texture-rectangle:hover .img-hover { opacity: 1; }
        .texture-rectangle:hover .img-base { opacity: 0; }

        /* БЛОК С ТЕКСТОМ (Вылетает справа) */
        .texture-rectangle .text-block {
            position: absolute;
            right: 0;
            top: 0;
            width: 50%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: flex-end;
            padding: 60px 40px;
            box-sizing: border-box;
            z-index: 5;
            animation: textFlyIn 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
        }

        /* Большой текст (Справа-Сверху) в стиле классических шрифтов */
        .cyber-title {
            margin: 0;
            font-size: 2.5rem;
            font-weight: bold;
            color: #ffffff; /* Чистый белый, как текст на синем экране смерти или заставках */
            text-shadow: 2px 2px 0px #000000; /* Четкая пиксельная тень букв вместо размытия */
            font-family: "MS Sans Serif", Geneva, sans-serif;
            text-align: right;
        }

        /* Маленький текст (Справа-Внизу) */
        .cyber-subtitle {
            margin: 0;
            font-size: 1rem;
            color: #ffff00; /* Ярко-желтый ретро-текст для привлечения внимания */
            text-shadow: 1px 1px 0px #000000;
            font-family: "MS Sans Serif", Geneva, sans-serif;
            text-align: right;
            max-width: 320px;
            line-height: 1.4;
        }

        /* ШКАФ С ПОЛКАМИ КАК СЕРЫЙ ИНТЕРФЕЙС ПРОГРАММЫ */
        .bookcase {
            width: 100%;
            max-width: 1000px;
            margin: 30px auto;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .shelf {
            display: grid !important;
            grid-template-columns: repeat(5, 1fr) !important;
            width: 100%;
            box-sizing: border-box;
            background-color: #c0c0c0; /* Серый пластик Win95 */
            align-items: center;
            justify-content: center;
            padding: 15px;

            /* Сложная рамка: выдавливаем рамку программы */
            border-top: 2px solid #fff;
            border-left: 2px solid #fff;
            border-right: 2px solid #808080;
            border-bottom: 2px solid #808080;
            box-shadow: 1px 1px 0px 0px #000;
        }

        /* ЯЧЕЙКИ ШКАФА (КАК ВДАВЛЕННЫЕ ПОЛЯ ВВОДА) */
        .shelf-btn {
            width: 100%;
            height: 100%;
            min-height: 160px;
            margin: 0;
            box-sizing: border-box;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transform: scale(0.95);
            background-color: #ffffff; /* Белые текстовые поля внутри серого окна */
            color: #000000;
            font-family: "MS Sans Serif", Geneva, sans-serif;
            font-size: 14px;
            font-weight: normal;

            /* Эффект глубокого вдавливания (Поле текстового ввода) */
            border-top: 2px solid #808080;
            border-left: 2px solid #808080;
            border-right: 2px solid #fff;
            border-bottom: 2px solid #fff;
            box-shadow: inset 1px 1px 0px #000;
            transition: none;
        }

        .shelf-btn:hover {
            background-color: #f0f0f0; /* Легкое изменение при наведении */
        }

        /* КНОПКА "ОЗВУЧИТЬ" */
        .custom-btn {
          width: 130px;
          height: 40px;
          color: #000;
          padding: 5px 20px;
          font-family: "MS Sans Serif", sans-serif;
          font-weight: normal;
          background-color: #c0c0c0;
          cursor: pointer;
          position: relative;
          display: inline-block;
          outline: none;

          /* Стандартная дефолтная кнопка Windows */
          border-top: 2px solid #fff;
          border-left: 2px solid #fff;
          border-right: 2px solid #808080;
          border-bottom: 2px solid #808080;
          box-shadow: 1px 1px 0px 0px #000;
        }

        .btn-1 {
          background-color: #c0c0c0;
          border-top: 2px solid #fff;
          border-left: 2px solid #fff;
          border-right: 2px solid #808080;
          border-bottom: 2px solid #808080;
        }

        .btn-1:active {
           border-top: 2px solid #808080;
           border-left: 2px solid #808080;
           border-right: 2px solid #fff;
           border-bottom: 2px solid #fff;
           box-shadow: none;
           transform: translate(1px, 1px);
        }

        .list-item a {
            color: #000080; /* Классический темно-синий цвет гиперссылок старого интернета */
            text-decoration: underline;
        }

        .list-item a:hover {
            color: #0000ff; /* Яркий синий при наведении */
        }

        .retro-icon {
            position: absolute;
            width: 32px;
            height: 32px;
            user-select: none;
            pointer-events: none;
            z-index: -10;
            image-rendering: pixelated; /* Убирает любое сглаживание иконок рабочего стола */
        }

        /* АНИМАЦИИ */
        @keyframes smoothFlyIn {
            from { transform: translate(-100vw, 0); opacity: 0; }
            to { transform: translate(20px, 0); opacity: 1; }
        }
        button {
          cursor: pointer;
        }

        div {
          cursor: help;
        }

        input {
          cursor: not-allowed;
        }

        p {
          cursor: zoom-in;
        }

